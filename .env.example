# Breeez environment variables — copy to .env.local for dev, set in Vercel for prod.
# Never commit a real .env file.

# === Public (browser-readable) ===
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# App store / Capacitor
NEXT_PUBLIC_APP_NAME=Breeez
NEXT_PUBLIC_SUPPORT_EMAIL=support@breeez.app

# === Server-only (NEVER prefix with NEXT_PUBLIC_) ===
# Supabase service role (for admin ops, webhooks) — server routes only
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Payment gateways — Phase 2 (plan Task 18)
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true

YOCO_SECRET_KEY=
YOCO_PUBLIC_KEY=

OZOW_SITE_CODE=
OZOW_PRIVATE_KEY=
OZOW_SANDBOX=true

# Couriers — Phase 2 (plan Task 19)
PARGO_API_KEY=
THE_COURIER_GUY_API_KEY=
DAWN_WING_API_KEY=

# Email (Resend) — Phase 2 (plan Task 20)
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@breeez.app

# Analytics (PostHog) — Phase 2
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Push notifications — Phase 2
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=